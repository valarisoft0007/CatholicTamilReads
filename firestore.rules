rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /books/{bookId} {
      allow read: if true;
      allow write: if false;

      match /chapters/{chapterId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ── News ────────────────────────────────────────────────────────────────
    // Reads are open — news items are public content.
    // All writes go through Admin SDK API routes (/api/admin/news/*) and
    // bypass these rules, so client writes are blocked entirely.
    match /news/{newsId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{uid} {
      allow read, create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;

      match /readingProgress/{bookId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /bookmarks/{bookmarkId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == uid;
      }

      match /favorites/{bookId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == uid;
      }
    }

  }
}
